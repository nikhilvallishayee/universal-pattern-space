{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Pattern Space v1 ruvector configuration - uses shared PostgreSQL",
  "storage": {
    "type": "postgres",
    "config": {
      "database": "pattern_space_memory",
      "host": "${POSTGRES_HOST:-localhost}",
      "port": "${POSTGRES_PORT:-5432}",
      "user": "${POSTGRES_USER:-pattern_space_app}",
      "password": "${POSTGRES_PASSWORD:-pattern_space_dev}",
      "schema": "ruvector"
    }
  },
  "vector": {
    "dimensions": 384,
    "distance_metric": "cosine",
    "index_type": "ivfflat",
    "ivf_lists": 100
  },
  "embedding": {
    "provider": "openai",
    "model": "text-embedding-3-small",
    "api_key": "${OPENAI_API_KEY}"
  },
  "collections": {
    "trajectories": {
      "description": "Successful task execution paths",
      "metadata_schema": {
        "agent": "string",
        "user": "string",
        "session": "string",
        "confidence": "float",
        "timestamp": "datetime"
      }
    },
    "reasoning_bank": {
      "description": "Proven reasoning patterns from sessions",
      "metadata_schema": {
        "type": "string",
        "session": "string",
        "persona": "string",
        "tasks": "int",
        "confidence": "float",
        "breakthroughs": "int",
        "timestamp": "datetime"
      }
    },
    "breakthroughs": {
      "description": "High-confidence breakthrough moments",
      "metadata_schema": {
        "agent": "string",
        "session": "string",
        "confidence": "float",
        "perspectives_involved": "array",
        "collision_type": "string",
        "timestamp": "datetime"
      }
    }
  },
  "mcp_server": {
    "name": "ruvector",
    "tools": [
      "vector_search",
      "vector_store",
      "store_trajectory",
      "find_similar",
      "list_collections",
      "collection_stats"
    ]
  },
  "version": "v1.1"
}
