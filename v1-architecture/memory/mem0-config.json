{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Pattern Space v1 mem0 configuration - uses shared PostgreSQL",
  "llm": {
    "provider": "anthropic",
    "config": {
      "model": "claude-sonnet-4-20250514",
      "temperature": 0.1,
      "max_tokens": 4096
    }
  },
  "vector_store": {
    "provider": "pgvector",
    "config": {
      "dbname": "pattern_space_memory",
      "host": "${POSTGRES_HOST:-localhost}",
      "port": "${POSTGRES_PORT:-5432}",
      "user": "${POSTGRES_USER:-pattern_space_app}",
      "password": "${POSTGRES_PASSWORD:-pattern_space_dev}",
      "collection_name": "memories",
      "schema": "mem0",
      "embedding_dims": 384
    }
  },
  "embedder": {
    "provider": "openai",
    "config": {
      "model": "text-embedding-3-small",
      "api_key": "${OPENAI_API_KEY}"
    }
  },
  "custom_categories": [
    {
      "name": "pattern",
      "description": "Recurring insights and connections"
    },
    {
      "name": "breakthrough",
      "description": "High-confidence novel discoveries"
    },
    {
      "name": "trajectory",
      "description": "Successful reasoning paths"
    },
    {
      "name": "evolution",
      "description": "Perspective development tracking"
    },
    {
      "name": "session_summary",
      "description": "Compressed session insights"
    }
  ],
  "history_db_path": null,
  "version": "v1.1"
}
